#!/usr/bin/env python

import os
import sys


def _add_import_root():
    script_dir = os.path.dirname(os.path.abspath(__file__))
    parent_dir = os.path.dirname(script_dir)
    deploy_python = os.path.join(parent_dir, "python", "packetlib")
    if os.path.isdir(deploy_python):
        import_root = os.path.join(parent_dir, "python")
    else:
        import_root = parent_dir
    if import_root not in sys.path:
        sys.path.insert(0, import_root)


_add_import_root()

from packetlib.cli import main_pktpcap  # noqa: E402


if __name__ == "__main__":
    sys.exit(main_pktpcap())
