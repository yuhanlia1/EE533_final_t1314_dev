    bit_width : 72;
    bit_from : 71;
    bit_to : 0;
    downto : true;
  }
  type (placeholder_fifo_bram_256x72_dp_douta_TYPE) {
    base_type : array;
    data_type : bit;
    bit_width : 72;
    bit_from : 71;
    bit_to : 0;
    downto : true;
  }
  type (placeholder_fifo_bram_256x72_dp_doutb_TYPE) {
    base_type : array;
    data_type : bit;
    bit_width : 72;
    bit_from : 71;
    bit_to : 0;
    downto : true;
  }
  cell(placeholder_fifo_bram_256x72_dp) {
    area : 16800.000;
    interface_timing : true;
    pg_pin(VDD) {
      voltage_name : "VDD";
      pg_type : primary_power;
    }
    pg_pin(VSS) {
      voltage_name : "VSS";
      pg_type : primary_ground;
    }
    pin(clka) {
      direction : input;
      capacitance : 25.000;
      clock : true;
    }
    pin(wea) {
      direction : input;
      capacitance : 5.000;
      clock : false;
    }
    bus(addra) {
      bus_type : placeholder_fifo_bram_256x72_dp_addra_TYPE;
      direction : input;
      capacitance : 5.000;
    }
    bus(dina) {
      bus_type : placeholder_fifo_bram_256x72_dp_dina_TYPE;
      direction : input;
      capacitance : 5.000;
    }
    pin(clkb) {
      direction : input;
      capacitance : 25.000;
      clock : true;
    }
    pin(web) {
      direction : input;
      capacitance : 5.000;
      clock : false;
    }
    bus(addrb) {
      bus_type : placeholder_fifo_bram_256x72_dp_addrb_TYPE;
      direction : input;
      capacitance : 5.000;
    }
    bus(dinb) {
      bus_type : placeholder_fifo_bram_256x72_dp_dinb_TYPE;
      direction : input;
      capacitance : 5.000;
    }
    bus(douta) {
      bus_type : placeholder_fifo_bram_256x72_dp_douta_TYPE;
      direction : output;
      max_capacitance : 500.000;
      timing() {
        related_pin : "clka";
        timing_type : rising_edge;
        timing_sense : non_unate;
        cell_rise(scalar) { values ("0.500"); }
        cell_fall(scalar) { values ("0.500"); }
        rise_transition(scalar) { values ("0.050"); }
        fall_transition(scalar) { values ("0.050"); }
      }
    }
    bus(doutb) {
      bus_type : placeholder_fifo_bram_256x72_dp_doutb_TYPE;
      direction : output;
      max_capacitance : 500.000;
      timing() {
        related_pin : "clkb";
        timing_type : rising_edge;
        timing_sense : non_unate;
        cell_rise(scalar) { values ("0.500"); }
        cell_fall(scalar) { values ("0.500"); }
        rise_transition(scalar) { values ("0.050"); }
        fall_transition(scalar) { values ("0.050"); }
      }
    }
