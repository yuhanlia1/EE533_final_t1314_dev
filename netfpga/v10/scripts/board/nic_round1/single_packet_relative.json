      "warmup_count": 5,
      "sample_count": 20,
      "single_result_timeout_seconds": 2.0,
      "inter_sample_pause_seconds": 0.05
    },
    {
      "name": "single_wrong_port_relative",
      "mode": "latency_single",
      "single_packet_variant": "wrong_port",
      "request_id_base": "0x1300",
      "warmup_count": 5,
      "sample_count": 20,
      "single_result_timeout_seconds": 2.0,
      "inter_sample_pause_seconds": 0.05
    }
  ]
